{
  "freq": "1d",
  "strategy_mode": "limit_up_screening",
  "lookback": 20,
  "rebalance_every": 5,
  "topk": 6,
  "topn_max": 6,
  "min_bars": 160,
  "max_codes_scan": 4000,
  "cash": 1000000.0,
  "commission": 0.0001,
  "stamp_duty": 0.0005,
  "slippage": 0.002,
  "calendar_code": "000001",
  "start_date": "2016-01-01",
  "end_date": "2025-07-01",
  "risk_free_rate": 0.03,
  "research_hypothesis": "Repeated historical limit-up behaviour may identify A-share names re-accumulating near their breakout origin, but only after leakage, tradability, and robustness gates pass.",
  "stock_num": 6,
  "limit_days_window": 250,
  "top_pct_limit_up": 0.1,
  "limit_up_threshold": 0.095,
  "init_pool_size": 1000,
  "rebalance_weekday": 1,
  "min_new_listing_days": 375,
  "stoploss_limit": 0.91,
  "take_profit_ratio": 2.0,
  "market_stoploss_ratio": 0.93,
  "loss_black_days": 20,
  "no_trade_months": [
    1,
    4
  ],
  "min_commission": 5.0,
  "baselines": {
    "benchmark_code": "000001",
    "enable_equal_weight": true,
    "random_trials": 200,
    "random_seed": 42
  },
  "universe_policy": {
    "canonical_universe_id": "cn_a_mainboard_all_v1",
    "definitions_dir": "configs/universes",
    "research_profile": "cn_a_mainboard_all_v1",
    "comparison_profiles": [
      "cn_a_mainboard_all_v1"
    ],
    "materialization_note": "Canonical universe is rebuilt from exchange security master metadata. ST and *ST are retained as labels only."
  },
  "coverage_gap_policy": {
    "decision_style": "canonical_universe_fixed",
    "auto_refreeze": false,
    "allow_universe_shrink": false,
    "required_end_date": "2025-07-01",
    "eligibility_min_bars": 160
  },
  "strategy_variants": {
    "baseline_limit_up": {
      "title": "baseline_limit_up",
      "decision_role": "control",
      "thesis": "Baseline reset control line on the new canonical universe.",
      "overrides": {}
    },
    "risk_constrained_limit_up": {
      "title": "risk_constrained_limit_up",
      "decision_role": "candidate",
      "thesis": "Legacy comparison branch retained for later re-evaluation after the new baseline is rebuilt.",
      "overrides": {
        "stock_num": 4,
        "topk": 4,
        "topn_max": 4
      }
    },
    "tighter_entry_limit_up": {
      "title": "tighter_entry_limit_up",
      "decision_role": "candidate",
      "thesis": "Legacy comparison branch retained for later re-evaluation after the new baseline is rebuilt.",
      "overrides": {
        "top_pct_limit_up": 0.08,
        "init_pool_size": 800
      }
    }
  },
  "tradability": {
    "require_positive_volume": true,
    "min_volume": 0.0
  },
  "data_provider": {
    "provider": "akshare",
    "market": "CN-A",
    "raw_layer": "raw",
    "cleaned_layer": "cleaned",
    "validated_layer": "validated",
    "symbol_format": "six_digit_a_share"
  },
  "research_validation": {
    "enabled": true,
    "forward_horizon_days": 1,
    "max_drawdown_limit": 0.3,
    "min_walk_forward_windows_alive": 2,
    "max_cost_sensitivity_drawdown_delta": 0.1,
    "min_cost_sensitivity_return_ratio": 0.5,
    "require_economic_rationale": true,
    "require_parameter_robustness": true,
    "parameter_perturbations": [
      {
        "limit_days_window": -0.2
      },
      {
        "limit_days_window": 0.2
      },
      {
        "top_pct_limit_up": -0.2
      },
      {
        "top_pct_limit_up": 0.2
      }
    ]
  },
  "agent": {
    "default_backend": "dry_run",
    "allow_live_execution": false,
    "max_cycles_per_run": 1,
    "require_promotion_gate": true,
    "default_tool_allowlist_path": "configs/tool_allowlist.yaml"
  },
  "factor_model": {
    "profile": "f1_elasticnet_v1",
    "feature_names": [
      "mom20",
      "rev5",
      "vol20",
      "range",
      "vol_surge",
      "ma_gap",
      "adv20",
      "amihud20"
    ],
    "label_horizon_days": 5,
    "refit_frequency": "monthly",
    "training_window_days": 756,
    "min_train_days": 504,
    "winsorize_quantile": 0.01,
    "standardization": "cross_sectional_zscore",
    "alpha": 0.001,
    "l1_ratio": 0.2,
    "max_iter": 5000
  },
  "deep_factor_model": {
    "profile": "f2_structured_latent_factor_v1",
    "base_feature_names": [
      "mom20",
      "rev5",
      "vol20",
      "range",
      "vol_surge",
      "ma_gap",
      "adv20",
      "amihud20"
    ],
    "group_features": true,
    "latent_dim": 4,
    "hidden_sizes": [
      12,
      4
    ],
    "activation": "relu",
    "alpha": 0.0001,
    "learning_rate_init": 0.001,
    "max_iter": 300,
    "early_stopping": true,
    "validation_fraction": 0.1,
    "random_state": 42,
    "label_horizon_days": 5,
    "refit_frequency": "monthly",
    "training_window_days": 756,
    "min_train_days": 504,
    "winsorize_quantile": 0.01,
    "standardization": "cross_sectional_zscore"
  },
  "regime_control": {
    "profile": "r1_predictive_error_overlay_v2",
    "ic_window_rebalances": 6,
    "shortfall_window_rebalances": 6,
    "min_history_rebalances": 6,
    "caution_ic_threshold": 0.0,
    "defensive_ic_threshold": -0.03,
    "caution_shortfall_threshold": -0.005,
    "defensive_shortfall_threshold": -0.015,
    "caution_exposure": 0.75,
    "defensive_exposure": 0.5,
    "cooldown_rebalances": 2
  },
  "risk_overlay": {
    "enabled": false,
    "vol_target": 0.18,
    "rolling_days": 20,
    "max_leverage": 1.0
  },
  "topk_multiplier": 2
}
